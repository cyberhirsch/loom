{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loom",
  "version": "0.1.0",
  "identifier": "com.cyberhirsch.loom",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Loom — weave living music",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
